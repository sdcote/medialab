{
  "RtwJob":{

    "Vault": { "filename": "[#$sys.app.home#][#$sys.file.separator#]sdcote.vault", "password": "[#$env.vault.password#]" },

    "Reader" : {
      "class" : "DirectoryReader",
      "directory" : "/Volumes/PRO-G40/Media/Phone/Videos",
      "pattern" : ".*"
    },

    "Transform": {
      "MediaDateClassifier": {  }
    },

    "Postprocess": {
      "MergeDirectory": {
        "source": "/Volumes/PRO-G40/Media/Phone/Videos",
        "target": "/Volumes/PRO-G40/Media/Videos",
        "move": true,
        "overwrite":false,
        "rename": true
      }
    },

    "Logging": {
      "StandardError": { "categories": "warn, error, fatal" },
      "StandardOutput": { "categories": "debug, trace, info, notice" }
    }

  }

}